# ============================================================
#  🐝 Hive — Environment Configuration
# ============================================================
#  Setup:  cp .env.example .env  &&  nano .env
#  Never commit your real .env — it is gitignored by default.
# ============================================================


# ════════════════════════════════════════════════════════════
#  LLM PROVIDERS  (slot-based, auto-rotating with fallback)
# ════════════════════════════════════════════════════════════
#  Slot 0 = primary (no suffix).  Slots 1–9 = fallbacks (suffix _1 … _9).
#
#  Per-slot variables:
#    LLM_API_KEY_N    single key (merged into the slot's key list)
#    LLM_API_KEYS_N   comma-separated keys → round-robin per request
#    LLM_MODELS_N     comma-separated models → fallback chain in the slot
#    LLM_API_URL_N    FULL endpoint URL. Protocol auto-detected:
#                       …/chat/completions  → OpenAI-compatible (default)
#                       …/messages          → Anthropic Messages API
#                       …/responses         → OpenAI Responses API
#                       (empty)             → Gemini SDK (needs google-genai)
#
#  Rules:
#    • A slot activates only when it has ≥1 key AND ≥1 model.
#    • Empty / partial slots auto-skip; gaps in slot numbers are fine.
#    • Multiline key lists MUST be quoted:
#          LLM_API_KEYS="key-aaa,
#          key-bbb,
#          key-ccc"
# ────────────────────────────────────────────────────────────

# ── Slot 0 — primary (REQUIRED) ──
LLM_API_KEY=your-primary-api-key
LLM_API_URL=https://api.example.com/v1/chat/completions
LLM_MODELS=your-model-name

# ── Slot 1 — fallback (optional, OpenAI-compatible) ──
# LLM_API_KEYS_1=key-a,key-b
# LLM_API_URL_1=https://provider-b.example.com/v1/chat/completions
# LLM_MODELS_1=model-1,model-2

# ── Slot 2 — fallback (optional, Gemini SDK — leave URL empty) ──
# LLM_API_KEY_2=your-gemini-key
# LLM_MODELS_2=gemini-2.0-flash,gemini-1.5-flash

# ── Slot 3 — fallback (optional, Anthropic Messages API) ──
# LLM_API_KEY_3=your-anthropic-key
# LLM_API_URL_3=https://provider-c.example.com/v1/messages
# LLM_MODELS_3=claude-model-name

# Retry attempts per slot (1–10, default 2)
AI_MAX_RETRIES=2


# ════════════════════════════════════════════════════════════
#  FACEBOOK GRAPH API
# ════════════════════════════════════════════════════════════
#  A User token is auto-resolved to a Page token via /me/accounts.
#  FB_APP_ID / FB_APP_SECRET are only needed for long-lived token exchange.
# ────────────────────────────────────────────────────────────
FB_PAGE_ID=your_page_id_here
FB_PAGE_ACCESS_TOKEN=your_page_access_token_here
FB_APP_ID=your_app_id_here
FB_APP_SECRET=your_app_secret_here


# ════════════════════════════════════════════════════════════
#  TELEGRAM NOTIFICATIONS  (optional)
# ════════════════════════════════════════════════════════════
#  Leave blank to disable. Alerts fire on startup, publish, error,
#  and daily summary — across both manual and scheduled posting.
# ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
